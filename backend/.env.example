# IOTA Network Configuration
IOTA_NETWORK=testnet
IOTA_RPC_URL=https://api.testnet.iota.cafe:443
IOTA_FAUCET_URL=https://faucet.testnet.iota.cafe

# Package ID (set after deploying Move contracts)
PACKAGE_ID=0x_YOUR_PACKAGE_ID_HERE

# Shared object IDs (set after deployment)
STAKE_POOL_ID=0x_YOUR_STAKE_POOL_ID_HERE

# Admin keypair (base64 encoded private key)
# Generate with: iota client new-address ed25519
ADMIN_PRIVATE_KEY=

# Server
PORT=3001
